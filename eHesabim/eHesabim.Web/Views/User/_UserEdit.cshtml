@using eHesabim.Framework.Localization

@model eHesabim.Web.Portal.Models.UserEditWebModel

@using (Ajax.BeginForm("_UserEdit", "User", new { Model.Id },
    new AjaxOptions {
        HttpMethod = "POST",
        OnSuccess = "onUserEditSuccess"
    }, new { id = "userEditForm" })) {

    <div>
        <div class="panel-body">
            <div class="form-group">
                <label>@Labels.UserName</label>
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = Labels.UserName, maxLength = 50, autocomplete = "off" })
                @Html.ValidationMessageFor(m => m.Name)
            </div>

            <div class="form-group">
                <label>@Labels.Email</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = Labels.Email, maxLength = 100, autocomplete = "off" })
                @Html.ValidationMessageFor(m => m.Email)
            </div>

            <div class="form-group">
                <label>@Labels.Password</label>
                @Html.TextBoxFor(m => m.Password, new { @class = "form-control", placeholder = Labels.Password, maxLength = 10, autocomplete = "off" })
            </div>

            <div class="form-group">
                <label>@Labels.Phone</label>
                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = Labels.Phone, maxLength = 10, autocomplete = "off" })
            </div>

            <div id="resultDiv"></div>

            <input type="submit" name="save" value="@Buttons.Save" class="btn btn-warning">
            <button type="button" onclick="closeModal('userEditWindow');" class="btn btn-outline btn-warning">@Buttons.Close</button>
        </div>
    </div>
}

<script type="text/javascript">
    $(document)
        .ready(function () {
            ValidateForm("userEditForm");
        });

    function onUserEditSuccess(data) {
        if (data.Success) {
            // Gridi refresh et
            $('#userGrid').data('kendoGrid').dataSource.read();
            // Pop-up ı kapat
            $("#userEditWindow").data("kendoWindow").close();
        } else {
            $('#resultDiv').html(data.Result);
        }
    }
</script>
