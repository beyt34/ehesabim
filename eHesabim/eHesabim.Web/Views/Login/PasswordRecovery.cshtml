@using eHesabim.Framework.Localization
@model eHesabim.Web.Portal.Models.UserPasswordRecoveryWebModel
@{
    Layout = "../Shared/_LayoutLogin.cshtml";
}

<div class="col-md-4 col-md-offset-4">
    <div class="login-panel panel panel-yellow">

        <div class="panel-heading">
            <h3 class="panel-title">@Headers.PasswordRecovery</h3>
        </div>

        <div class="panel-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "passwordRecoveryForm" })) {

                <div class="form-group">
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = Labels.Email })
                    @Html.ValidationMessageFor(m => m.Email)
                </div>

                if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
                    <div id="errorDiv" class="alert alert-danger">
                        @Html.Raw(Model.ErrorMessage)
                    </div>
                }

                if (!string.IsNullOrEmpty(Model.SuccessMessage)) {
                    <div id="successDiv" class="alert alert-success">
                        @Html.Raw(Model.SuccessMessage)
                    </div>
                }

                <input type="submit" name="send" class="btn btn-lg btn-warning btn-block" value="@Buttons.Send" />
            }
        </div>

    </div>

</div>
