  <configSections>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <connectionStrings>
    <add name="DataContext" connectionString="Server=.;Database=eHesabim;User Id=sa;Password=REDACTED_SQL_PASSWORD;" providerName="System.Data.SqlClient" />
    <!--<add name="DataContext" connectionString="Server=tcp:4flyy.database.windows.net,1433;Database=eHesabim;User ID=ehesabim;Password=REDACTED_AZURE_SQL_PASSWORD;Trusted_Connection=False;Encrypt=True;Connection Timeout=30;" providerName="System.Data.SqlClient" />-->
  </connectionStrings>
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="PreserveLoginUrl" value="true" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- Live -->
    <add key="PortalPath" value="http://localhost:16347" />
    <add key="FacebookAppId" value="571761169700315" />
    <add key="FacebookSecretKey" value="REDACTED_FACEBOOK_SECRET" />
    <add key="FacebookCallbackUrl" value="http://localhost:16347/Login/RegisterFacebook" />
    <!-- Storage -->
    <add key="FilePath" value="//ehesabim.blob.core.windows.net/" />
    <add key="StorageConnectionString" value="DefaultEndpointsProtocol=https;AccountName=ehesabim;AccountKey=REDACTED_AZURE_STORAGE_KEY==;EndpointSuffix=core.windows.net" />
  </appSettings>
  <system.web>
    <globalization culture="tr-TR" uiCulture="tr-TR" />
    <compilation debug="true" targetFramework="4.8" />
    <customErrors mode="Off" />
    <machineKey validationKey="REDACTED_MACHINEKEY_VALIDATION" decryptionKey="REDACTED_MACHINEKEY_DECRYPTION" validation="SHA1" decryption="AES" />
    <httpRuntime targetFramework="4.8" maxRequestLength="1048576" />
    <authentication mode="Forms">
      <forms loginUrl="~/Login" protection="All" timeout="1440" path="/" requireSSL="false" slidingExpiration="true" cookieless="UseCookies" />
    </authentication>
    <pages>
      <namespaces />
    </pages>
  </system.web>
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
  </system.webServer>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
      <parameters>
        <parameter value="v11.0" />
      </parameters>
    </defaultConnectionFactory>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
