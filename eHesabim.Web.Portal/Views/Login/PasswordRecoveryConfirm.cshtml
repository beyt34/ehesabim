@using eHesabim.Framework.Localization
@model eHesabim.Web.Portal.Models.UserPasswordRecoveryConfirmWebModel
@{
    Layout = "../Shared/_LayoutLogin.cshtml";
}

<div class="col-md-4 col-md-offset-4">
    <div class="login-panel panel panel-yellow">

        <div class="panel-heading">
            <h3 class="panel-title">@Headers.PasswordRecoveryConfirm</h3>
        </div>

        <div class="panel-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "passwordRecoveryConfirmForm" })) {
                @Html.HiddenFor(model => model.PasswordGuid)
                
                <div class="form-group">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = Labels.Password })
                    @Html.ValidationMessageFor(m => m.Password)
                </div>

                <div class="form-group">
                    @Html.PasswordFor(m => m.RePassword, new { @class = "form-control", placeholder = Labels.RePassword })
                    @Html.ValidationMessageFor(m => m.RePassword)
                </div>

                if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
                    <div id="errorDiv" class="alert alert-danger">
                        @Html.Raw(Model.ErrorMessage)
                    </div>
                }

                <input type="submit" name="send" class="btn btn-lg btn-warning btn-block" value="@Buttons.Save" />
            }
        </div>

    </div>

</div>
