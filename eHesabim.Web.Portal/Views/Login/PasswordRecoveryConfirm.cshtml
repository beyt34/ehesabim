@using eHesabim.Framework.Localization
@using eHesabim.Web.Portal.Engine
@model eHesabim.Web.Portal.Models.UserPasswordRecoveryConfirmWebModel
@{
    Layout = "../Shared/_LayoutLogin.cshtml";
}

<!-- Nested Row within Card Body -->
<div class="row">
    <div class="col-lg-6 d-none d-lg-block bg-login-image"></div>
    <div class="col-lg-6">
        <div class="p-5">
            <div class="text-center">
                <h1 class="h4 text-gray-900 mb-2">@Headers.PasswordRecoveryConfirm</h1>
                <p class="mb-4">E-posta adresinizi girin, şifrenizi sıfırlamanız için size bir link gönderelim!</p>
            </div>

            @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "passwordRecoveryConfirmForm", @class = "user" })) {
                @Html.HiddenFor(model => model.PasswordGuid)

                <div class="form-group">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-user", placeholder = Labels.Password })
                    @Html.ValidationMessageFor(m => m.Password)
                </div>

                <div class="form-group">
                    @Html.PasswordFor(m => m.RePassword, new { @class = "form-control form-control-user", placeholder = Labels.RePassword })
                    @Html.ValidationMessageFor(m => m.RePassword)
                </div>


                if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
                    <div id="errorDiv" class="card mb-2 border-left-danger">
                        <div class="card-body">
                            @Html.Raw(Model.ErrorMessage)
                        </div>
                    </div>
                }

                <input type="submit" name="save" class="btn btn-primary btn-user btn-block" value="@Buttons.Save" />
            }

            <hr>
            <div class="text-center">
                <a href="@Url.RouteUrl(RouteNames.Register)" class="small">@Buttons.Register</a>
            </div>
            <div class="text-center">
                <a href="@Url.RouteUrl(RouteNames.Login)" class="small">Zaten bir hesabın mı var? Giriş!</a>
            </div>
        </div>
    </div>
</div>