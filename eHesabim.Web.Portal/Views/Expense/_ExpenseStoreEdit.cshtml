@using eHesabim.Framework.Localization
@model eHesabim.Web.Portal.Models.ExpenseStoreEditWebModel

@using (Ajax.BeginForm("_ExpenseStoreEdit", "Expense", new { Model.Id },
 new AjaxOptions {
     HttpMethod = "POST",
     OnSuccess = "onExpenseStoreEditSuccess"
 }, new { @id = "expenseStoreEditForm" })) {

    <div>
        <div class="panel-body">
            <div class="form-group">
                <label>@Labels.ExpenseStoreName</label>
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = Labels.ExpenseStoreName, maxLength = 100 })
                @Html.ValidationMessageFor(m => m.Name)
            </div>

            <div id="resultDiv"></div>

            <input type="submit" name="save" value="@Buttons.Save" class="btn btn-warning">
            <button type="button" onclick="closeModal('expenseStoreEditWindow');" class="btn btn-outline btn-warning">@Buttons.Close</button>
        </div>
    </div>
}

<script type="text/javascript">
    $(document).ready(function () {
        ValidateForm("expenseStoreEditForm");
    });

    function onExpenseStoreEditSuccess(data) {
        if (data.Success) {
            // Gridi refresh et
            $('#expenseStoreGrid').data('kendoGrid').dataSource.read();
            // Pop-up ı kapat
            $("#expenseStoreEditWindow").data("kendoWindow").close();
        } else {
            $('#resultDiv').html(data.Result);
        }
    }
</script>