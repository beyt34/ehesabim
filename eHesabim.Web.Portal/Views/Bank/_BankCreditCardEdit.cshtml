@using eHesabim.Framework.Localization
@model eHesabim.Web.Portal.Models.BankCreditCardEditWebModel

@using (Ajax.BeginForm("_BankCreditCardEdit", "Bank", new { Model.Id },
 new AjaxOptions {
     HttpMethod = "POST",
     OnSuccess = "onBankCreditCardEditSuccess"
 }, new { @id = "bankCreditCardEditForm", @class = "form-horizontal" })) {
    <div>
        <div class="panel-body">

            <div class="form-group">
                <label class="col-sm-4">@Labels.BankCreditCardParent</label>
                <div class="col-sm-8">
                    @Html.DropDownListFor(m => m.ParentId, Model.ParentList, new { @class = "form-control" })
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.Bank</label>
                <div class="col-sm-8">
                    @Html.DropDownListFor(m => m.BankId, Model.BankList, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.BankId)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.BankCreditCardName</label>
                <div class="col-sm-8">
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = Labels.BankCreditCardName, maxLength = 20 })
                    @Html.ValidationMessageFor(m => m.Name)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.BankCreditCardNo</label>
                <div class="col-sm-8">
                    @Html.TextBoxFor(m => m.CardNo, new { @class = "form-control", placeholder = Labels.BankCreditCardNo, maxLength = 6 })
                    @Html.ValidationMessageFor(m => m.CardNo)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.BankCreditCardLimit</label>
                <div class="col-sm-8">
                    <div class="input-group">
                        @Html.TextBoxFor(m => m.Limit, new { @class = "form-control", placeholder = Labels.BankCreditCardLimit, maxLength = 10, onkeypress = "return OnlyNumberChars(event);", autocomplete = "off" })
                        <span class="input-group-addon">TL</span>
                    </div>
                    <div>@Html.ValidationMessageFor(m => m.Limit)</div>
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.Order</label>
                <div class="col-sm-8">
                    @Html.TextBoxFor(m => m.Order, new { @class = "form-control", placeholder = Labels.Order, maxLength = 2 })
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.IsActive</label>
                <div class="col-sm-8">
                    @Html.CheckBoxFor(m => m.IsActive)
                </div>
            </div>

            <div id="resultDiv"></div>

            <div class="form-group">
                <label class="col-sm-4">&nbsp;</label>
                <div class="col-sm-8">
                    <input type="submit" name="save" value="@Buttons.Save" class="btn btn-warning">
                    <button type="button" onclick="closeModal('bankCreditCardEditWindow');" class="btn btn-outline btn-warning">@Buttons.Close</button>
                </div>
            </div>

        </div>
    </div>
}

<script type="text/javascript">
    $(document).ready(function () {
        ValidateForm("bankCreditCardEditForm");
        Numeric("Order");
        onParentChanged();

        $("#ParentId").change(function () {
            onParentChanged();
        });
    });

    function onParentChanged() {
        var parentId = $("#ParentId").val();
        if (parentId != "") {
            $.ajax({
                url: "/Bank/GetBankId",
                data: { parentId: parentId },
                dataType: "json",
                type: "POST",
                success: function (bankId) {
                    $("#BankId").val(bankId);
                }
            });
        }

        $("#BankId").prop("disabled", (parentId != ""));
    }

    function onBankCreditCardEditSuccess(data) {
        if (data.Success) {
            // Gridi refresh et
            $('#bankCreditCardGrid').data('kendoGrid').dataSource.read();
            // Pop-up ı kapat
            $("#bankCreditCardEditWindow").data("kendoWindow").close();
        } else {
            $('#resultDiv').html(data.Result);
        }
    }
</script>
