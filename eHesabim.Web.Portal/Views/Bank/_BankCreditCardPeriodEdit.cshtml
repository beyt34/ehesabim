@using eHesabim.Framework.Localization
@using Kendo.Mvc.UI
@model eHesabim.Web.Portal.Models.BankCreditCardPeriodEditWebModel

@using (Ajax.BeginForm("_BankCreditCardPeriodEdit", "Bank", new { Model.Id },
 new AjaxOptions {
     HttpMethod = "POST",
     OnSuccess = "onBankCreditCardPeriodEditSuccess"
 }, new { @id = "bankCreditCardPeriodEditForm", @class = "form-horizontal" })) {
    <div>
        <div class="panel-body">

            <div class="form-group">
                <label class="col-sm-4">@Labels.BankCreditCard</label>
                <div class="col-sm-8">
                    @Html.DropDownListFor(m => m.BankCreditCardId, Model.BankCreditCardList, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.BankCreditCardId)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.StartDate</label>
                <div class="col-sm-8">
                    @Html.Kendo().DatePickerFor(m => m.StartDate).HtmlAttributes(new { type = "text" })
                    @Html.ValidationMessageFor(m => m.StartDate)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.EndDate</label>
                <div class="col-sm-8">
                    @Html.Kendo().DatePickerFor(m => m.EndDate).HtmlAttributes(new { type = "text" })
                    @Html.ValidationMessageFor(m => m.EndDate)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-4">@Labels.PaymentDate</label>
                <div class="col-sm-8">
                    @Html.Kendo().DatePickerFor(m => m.PaymentDate).HtmlAttributes(new { type = "text" })
                    @Html.ValidationMessageFor(m => m.PaymentDate)
                </div>
            </div>
            
            <div class="form-group">
                <label class="col-sm-4">@Labels.SetExpensePeriod</label>
                <div class="col-sm-8">
                    @Html.CheckBoxFor(m => m.SetExpense)
                </div>
            </div>
            
            <div id="resultDiv"></div>

            <div class="form-group">
                <label class="col-sm-4">&nbsp;</label>
                <div class="col-sm-8">
                    <input type="submit" name="save" value="@Buttons.Save" class="btn btn-warning">
                    <button type="button" onclick="closeModal('bankCreditCardPeriodEditWindow');" class="btn btn-outline btn-warning">@Buttons.Close</button>
                </div>
            </div>
        </div>
    </div>
}

<script type="text/javascript">
    $(document).ready(function () {
        ValidateForm("bankCreditCardPeriodEditForm");
    });

    function onBankCreditCardPeriodEditSuccess(data) {
        if (data.Success) {
            // Gridi refresh et
            $('#bankCreditCardPeriodGrid').data('kendoGrid').dataSource.read();
            // Pop-up ı kapat
            $("#bankCreditCardPeriodEditWindow").data("kendoWindow").close();
        } else {
            $('#resultDiv').html(data.Result);
        }
    }
</script>
