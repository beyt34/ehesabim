@using eHesabim.Framework.Localization
@using Kendo.Mvc.UI
@model eHesabim.Web.Portal.Models.BankAccountListWebModel

<div class="row">
    <div class="col-lg-12">
        &nbsp;
    </div>
</div>

<div class="panel panel-yellow">

    <div class="panel-heading">
        <h3 class="panel-title">
            <i class="fa fa-fire fa-fw"></i> @Headers.BankAccountList
        </h3>
    </div>

    <div class="panel-body">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "bankAccountForm" })) {
            <div class="form-group">
                <label>@Html.Raw(Labels.AccountType)</label>
                @Html.DropDownListFor(m => m.SearchTypeId, Model.SearchTypeList, new { @class = "form-control", placeholder = Labels.AccountType })
            </div>
            <div class="form-group">
                <label>@Html.Raw(Labels.Bank)</label>
                @Html.DropDownListFor(m => m.SearchBankId, Model.SearchBankList, new { @class = "form-control", placeholder = Labels.Bank })
            </div>
            
            <a href="#" id="form-search" class="UIButton btn btn-warning">@Buttons.Search</a>
            <a href="#" id="form-detail" class="btn btn-outline btn-warning">@Buttons.Add</a>
        }

        <hr />

        <div class="table-responsive col-xs-12">
            @(Html.Kendo().Grid(Model.Data)
                  .Name("bankAccountGrid")
                  .Columns(columns => {
                      columns.Bound(x => x.TypeName).Title(Labels.AccountType);
                      columns.Bound(x => x.Name).Title(Labels.AccountName);
                      columns.Bound(x => x.BankName).Title(Labels.Bank);
                      columns.Bound(x => x.Iban).Title(Labels.Iban);
                      columns.Bound(x => x.Limit).Format("{0:N2}").HtmlAttributes(new { style = "text-align:right;" }).Title(Labels.AccountLimit);
                      columns.Bound(x => x.IsActive).HtmlAttributes(new { style = "text-align:center;" }).ClientTemplate("<input type='checkbox' name='chkIsActive' #= IsActive ? checked='checked' : '' # disabled />").Title(Labels.IsActive);
                      columns.Command(x => x.Custom(Buttons.Edit).Click("onBankAccountEditWindow")).Width(50).HtmlAttributes(new { cmd = "edit", style = "text-align:center;" });
                      columns.Command(x => x.Custom(Buttons.Delete).Click("onDeleteWindow")).Width(50).HtmlAttributes(new { cmd = "delete", style = "text-align:center;" });
                  })
                  .Pageable(p => p.Refresh(true).PreviousNext(true))
                  .Sortable()
                  .EnableCustomBinding(true)
                  .Events(events => events.DataBound("onGridDataBound"))
                  .DataSource(dataSource => dataSource
                        .Ajax()
                        .Model(m => m.Id(p => p.Id))
                        .PageSize(20)
                        .Total(Model.Total)
                        .Read(read => read.Action("BankAccountList", "BankAccount").Data("GetSearchModel"))
                  )
            )
        </div>

    </div>
</div>

@{Html.Kendo().Window()
          .Name("bankAccountEditWindow")
          .Title(Headers.BankAccountEdit)
          .Draggable(true)
          .Modal(true)
          .Visible(false)
          .Render();
}

@Html.Partial("_DeleteWindow", Model.DeleteData)

@section scripts{
    <script type="text/javascript">
        $(document).ready(function () {
            DefaultButton("bankAccountForm", "form-search");

            $('#form-search').click(function () {
                FormSearch(GetSearchModel(true), "bankAccountGrid");
            });

            $('#form-detail').click(function () {
                var wnd = $("#bankAccountEditWindow").kendoWindow({
                    content: {
                        url: "/BankAccount/_BankAccountEdit"
                    }
                }).data("kendoWindow");

                wnd.wrapper.addClass("col-sm-8 col-xs-10 max-width-650");
                wnd.center();
                wnd.open();
            });
        });

        //SetLeftMenu("liBank");
        SetLeftMenu("collapseBankAccount");

        function onBankAccountEditWindow(e) {
            e.preventDefault();
            var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
            openModal("bankAccountEditWindow", "/BankAccount/_BankAccountEdit", dataItem.Id, "md");
        }

        function GetSearchModel(searchViaForm) {
            return {
                SearchTypeId: $('#SearchTypeId').val(),
                SearchBankId: $('#SearchBankId').val(),
                SearchViaForm: searchViaForm == undefined ? false : searchViaForm
            };
        }
    </script>
}
