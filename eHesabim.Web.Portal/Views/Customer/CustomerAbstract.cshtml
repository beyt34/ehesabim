@using eHesabim.Framework.Localization
@using Kendo.Mvc.UI
@model eHesabim.Web.Portal.Models.CustomerAbstractWebModel

<div class="row">
    <div class="col-lg-12">
        &nbsp;
    </div>
</div>

<div class="panel panel-yellow">

    <div class="panel-heading">
        <h3 class="panel-title">
            <i class="fa fa-bar-chart-o fa-fw"></i> @Headers.CustomerAbstract
        </h3>
    </div>

    <div class="panel-body">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "customerAbstractForm", @class = "form-horizontal" })) {

            <div class="form-group">
                <label class="col-sm-2">@Html.Raw(Labels.Customer)</label>
                <div class="col-sm-10">
                    @Html.DropDownListFor(m => m.CustomerId, Model.CustomerList, new { @class = "form-control", placeholder = Labels.Customer })
                    @Html.ValidationMessageFor(m => m.CustomerId)
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-2">@Html.Raw(Labels.StartDate)</label>
                <div class="col-sm-10">
                    @Html.Kendo().DatePickerFor(m => m.StartDate).HtmlAttributes(new { type = "text" })
                </div>
            </div>

            <div class="form-group">
                <label class="col-sm-2">@Html.Raw(Labels.EndDate)</label>
                <div class="col-sm-10">
                    @Html.Kendo().DatePickerFor(m => m.EndDate).HtmlAttributes(new { type = "text" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-sm-2">&nbsp;</div>
                <div class="col-sm-10">
                    <button type="submit" name="excel-export" value="excel-export" class="btn btn-warning">@Buttons.ExcelExport</button>
                </div>
            </div>
        }

        <hr />

    </div>
</div>

@section scripts{
    <script type="text/javascript">
        SetLeftMenu("liCustomer");
    </script>
}
