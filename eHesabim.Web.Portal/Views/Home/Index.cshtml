@using eHesabim.Framework.Localization
@using eHesabim.Web.Portal.Engine
@model eHesabim.Web.Portal.Models.DashboardWebModel

@{
    // customer
    var customerDebitTotal = 0.0M;
    var customerClaimTotal = 0.0M;
    var customerNetTotal = 0.0M;
    var customerDueDebitTotal = 0.0M;

    // bank account
    var bankAccountDebitTotal = 0.0M;
    var bankAccountClaimTotal = 0.0M;
    var bankAccountNetTotal = 0.0M;

    // credit
    var capitalTotal = 0.0M;
    var monthlyPaymentTotal = 0.0M;
    var remainCapitalTotal = 0.0M;

    // credit card
    var limitTotal = 0.0M;
    var availableLimitTotal = 0.0M;
    var lastDebtTotal = 0.0M;
    var currentDebtTotal = 0.0M;
    var nextDebtTotal = 0.0M;
    var debtTotal = 0.0M;
}

@if (WorkContext.CurrentUser.ShowCustomer) {
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <a href="@Url.RouteUrl(RouteNames.CustomerTransactionList)"><i class="fa fa-th-large fa-fw"></i> @Headers.Customer</a>
            </h6>
        </div>
        @if (Model.Customers != null && Model.Customers.Any()) {
            <div class="card-body">
                <div class="table-responsive">
                    <div class="dataTables_wrapper dt-bootstrap4">
                        <div class="row">
                            <div class="col-sm-12">
                                <table class="table table-bordered dataTable" role="grid">
                                    <thead>
                                        <tr role="row" class="bg-gradient-primary text-white">
                                            <th class="col-sm-2">@Html.Raw(Labels.CustomerName)</th>
                                            <th class="col-sm-3" style="text-align: right;">@Html.Raw(Labels.Debit)</th>
                                            <th class="col-sm-3" style="text-align: right;">@Html.Raw(Labels.Claim)</th>
                                            <th class="col-sm-2" style="text-align: right;">@Html.Raw(Labels.Net)</th>
                                            <th class="col-sm-2" style="text-align: right;">@Html.Raw(Labels.DueDebit)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Customers) {
                                            customerDebitTotal += item.Debit;
                                            customerClaimTotal += item.Claim;
                                            customerNetTotal += item.Net;
                                            customerDueDebitTotal += item.DueDebit;

                                            var trClass = item.Net < 0 ? "border-left-danger" : "border-left-success";
                                            var nameExt = item.IsExclusion ? string.Format("(*) {0}", item.Name) : item.Name;

                                            <tr role="row" class="@trClass">
                                                <td>@Html.Raw(nameExt)</td>
                                                <td style="text-align: right;">@Html.Raw(item.Debit.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.Claim.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.Net.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.DueDebit.ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr role="row">
                                            <th><label></label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(customerDebitTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(customerClaimTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(customerNetTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(customerDueDebitTotal.ToString("N2"))</label></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else {
            @Html.Raw(Messages.ReportDataEmpty)
        }
    </div>
}

@if (WorkContext.CurrentUser.ShowAccount) {
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <a href="@Url.RouteUrl(RouteNames.BankAccountTransactionList)"><i class="fa fa-bookmark fa-fw"></i> @Headers.BankAccounts</a>
            </h6>
        </div>
        @if (Model.BankAccounts != null && Model.BankAccounts.Any()) {
            <div class="card-body">
                <div class="table-responsive">
                    <div class="dataTables_wrapper dt-bootstrap4">
                        <div class="row">
                            <div class="col-sm-12">
                                <table class="table table-bordered dataTable" role="grid">
                                    <thead>
                                        <tr role="row" class="bg-gradient-primary text-white">
                                            <th class="col-sm-2">@Html.Raw(Labels.BankAccount)</th>
                                            <th class="col-sm-3" style="text-align: right;">@Html.Raw(Labels.Debit)</th>
                                            <th class="col-sm-3" style="text-align: right;">@Html.Raw(Labels.Claim)</th>
                                            <th class="col-sm-2" style="text-align: right;">@Html.Raw(Labels.Net)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.BankAccounts) {
                                            bankAccountDebitTotal += item.DebitTotal;
                                            bankAccountClaimTotal += item.ClaimTotal;
                                            bankAccountNetTotal += item.NetTotal;

                                            var trClass = item.NetTotal < 0 ? "border-left-danger" : "border-left-success";

                                            <tr role="row" class="@trClass">
                                                <td>@Html.Raw(item.Name)</td>
                                                <td style="text-align: right;">@Html.Raw(item.DebitTotal.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.ClaimTotal.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.NetTotal.ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr role="row">
                                            <th><label></label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(bankAccountDebitTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(bankAccountClaimTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(bankAccountNetTotal.ToString("N2"))</label></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else {
            @Html.Raw(Messages.ReportDataEmpty)
        }
    </div>
}

@if (WorkContext.CurrentUser.ShowCredit) {
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <a href="@Url.RouteUrl(RouteNames.BankCreditSubList)"><i class="fa fa-suitcase fa-fw"></i> @Headers.BankCredits</a>
            </h6>
        </div>
        @if (Model.BankCredits != null && Model.BankCredits.Any()) {
            <div class="card-body">
                <div class="table-responsive">
                    <div class="dataTables_wrapper dt-bootstrap4">
                        <div class="row">
                            <div class="col-sm-12">
                                <table class="table table-bordered dataTable" role="grid">
                                    <thead>
                                        <tr role="row" class="bg-gradient-primary text-white">
                                            <th class="col-sm-1">@Labels.Bank</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.Installment</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.RemainInstallment</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.PaymentDate</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.MonthlyPayment</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.Capital</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.RemainCapital</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.BankCredits) {
                                            monthlyPaymentTotal += item.MonthlyPayment;
                                            capitalTotal += item.Capital;
                                            remainCapitalTotal += item.RemainCapital;
                                            
                                            var day = item.PaymentDateTime == DateTime.MinValue ? 999 : item.PaymentDateTime.Subtract(DateTime.Today).TotalDays;
                                            var trClass = day <= 0 ? "border-left-danger" : day <= 15 ? "border-left-warning" : "border-left-success";

                                            <tr role="row" class="@trClass">
                                                <td>@Html.Raw(item.BankName)</td>
                                                <td style="text-align: right;">@Html.Raw(item.Installment.ToString("N0"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.RemainInstallment.ToString("N0"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.PaymentDateTime != DateTime.MinValue ? item.PaymentDateTime.ToString("dd.MM.yyyy") : string.Empty)</td>
                                                <td style="text-align: right;">@Html.Raw(item.MonthlyPayment.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.Capital.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.RemainCapital.ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr role="row">
                                            <th><label></label></th>
                                            <th><label></label></th>
                                            <th><label></label></th>
                                            <th><label></label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(monthlyPaymentTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(capitalTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(remainCapitalTotal.ToString("N2"))</label></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else {
            @Html.Raw(Messages.ReportDataEmpty)
        }
    </div>
}

@if (WorkContext.CurrentUser.ShowCard) {
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <a href="@Url.RouteUrl(RouteNames.ExpenseList)"><i class="fa fa-briefcase fa-fw"></i> @Headers.BankCreditCards</a>
            </h6>
        </div>
        @if (Model.BankCreditCards != null && Model.BankCreditCards.Any()) {
            <div class="card-body">
                <div class="table-responsive">
                    <div class="dataTables_wrapper dt-bootstrap4">
                        <div class="row">
                            <div class="col-sm-12">
                                <table class="table table-bordered dataTable" role="grid">
                                    <thead>
                                        <tr role="row" class="bg-gradient-primary text-white">
                                            <th class="col-sm-1">@Labels.BankCreditCardName</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.BankCreditCardLimit</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.AvailableLimit</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.EndDate</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.PaymentDate</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.LastDebt</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.CurrentDebt</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.NextDebt</th>
                                            <th class="col-sm-1" style="text-align: right;">@Labels.DebtTotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.BankCreditCards) {
                                            limitTotal += item.Limit;
                                            availableLimitTotal += item.AvailableLimit;
                                            lastDebtTotal += item.LastDebt;
                                            currentDebtTotal += item.CurrentDebt;
                                            nextDebtTotal += item.NextDebt;
                                            debtTotal += item.DebtTotal;

                                            var day = item.PaymentDateTime == DateTime.MinValue ? 999 : item.PaymentDateTime.Subtract(DateTime.Today).TotalDays;
                                            var trClass = day <= 0 ? "border-left-danger" : day <= 15 ? "border-left-warning" : "border-left-success";

                                            <tr role="row" class="@trClass">
                                                <td>@Html.Raw(item.Name)</td>
                                                <td style="text-align: right;">@Html.Raw(item.Limit.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.AvailableLimit.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.EndDateTime != DateTime.MinValue ? item.EndDateTime.ToString("dd.MM.yyyy") : string.Empty)</td>
                                                <td style="text-align: right;">@Html.Raw(item.PaymentDateTime != DateTime.MinValue ? item.PaymentDateTime.ToString("dd.MM.yyyy") : string.Empty)</td>
                                                <td style="text-align: right;">@Html.Raw(item.LastDebt.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.CurrentDebt.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.NextDebt.ToString("N2"))</td>
                                                <td style="text-align: right;">@Html.Raw(item.DebtTotal.ToString("N2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr role="row">
                                            <th><label></label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(limitTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(availableLimitTotal.ToString("N2"))</label></th>
                                            <th><label></label></th>
                                            <th><label></label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(lastDebtTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(currentDebtTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(nextDebtTotal.ToString("N2"))</label></th>
                                            <th style="text-align: right;"><label>@Html.Raw(debtTotal.ToString("N2"))</label></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else {
            @Html.Raw(Messages.ReportDataEmpty)
        }
    </div>
}

<!-- Alt Toplamlar -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        @if (WorkContext.CurrentUser.ShowCustomer) {
            <tr>
                <th class="col-xs-4" style="vertical-align: middle;">
                    <label>@Headers.Customer</label>
                </th>
                <td class="col-xs-8">
                    <div class="input-group">
                        <input type="text" class="form-control" value="@Html.Raw(customerNetTotal.ToString("N2"))" style="text-align: right;" readonly="readonly"/>
                        <span class="input-group-addon">TL</span>
                    </div>
                </td>
            </tr>
        }

        @if (WorkContext.CurrentUser.ShowAccount) {
            <tr>
                <th style="vertical-align: middle;">
                    <label>@Headers.BankAccounts</label>
                </th>
                <td>
                    <div class="input-group">
                        <input type="text" class="form-control" value="@Html.Raw(bankAccountNetTotal.ToString("N2"))" style="text-align: right;" readonly="readonly"/>
                        <span class="input-group-addon">TL</span>
                    </div>
                </td>
            </tr>
        }

        @if (WorkContext.CurrentUser.ShowCredit) {
            <tr>
                <th style="vertical-align: middle;">
                    <label>@Headers.BankCredits</label>
                </th>
                <td>
                    <div class="input-group">
                        <input type="text" class="form-control" value="@Html.Raw(remainCapitalTotal.ToString("N2"))" style="text-align: right;" readonly="readonly"/>
                        <span class="input-group-addon">TL</span>
                    </div>
                </td>
            </tr>
        }

        @if (WorkContext.CurrentUser.ShowCard) {
            <tr>
                <th style="vertical-align: middle;">
                    <label>@Headers.BankCreditCards</label>
                </th>
                <td>
                    <div class="input-group">
                        <input type="text" class="form-control" value="@Html.Raw(debtTotal.ToString("N2"))" style="text-align: right;" readonly="readonly"/>
                        <span class="input-group-addon">TL</span>
                    </div>
                </td>
            </tr>
        }

        <tr>
            <th style="vertical-align: middle;">
                <label>@Labels.AssetTotal</label>
            </th>
            <td>
                <div class="input-group">
                    @{ var assetTotal = customerNetTotal + bankAccountNetTotal - remainCapitalTotal - debtTotal; }
                    <input type="text" class="form-control" value="@Html.Raw(assetTotal.ToString("N2"))" style="text-align: right;" readonly="readonly"/>
                    <span class="input-group-addon">TL</span>
                </div>
            </td>
        </tr>
    </table>
</div>

@section scripts{
    <script type="text/javascript">
        $(document).ready(function () {
        });
    </script>
}