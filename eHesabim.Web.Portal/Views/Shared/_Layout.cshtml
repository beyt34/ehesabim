<body id="page-top">
    <noscript><div><img src="https://mc.yandex.ru/watch/32268614" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- Page Wrapper -->
    <div id="wrapper">
        @Html.Partial("MenuSidebar")

        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">
            <!-- Main Content -->
            <div id="content">
                <!-- Topbar -->
                @Html.Partial("MenuTopbar")
                <!-- End of Topbar -->
                
                <!-- Begin Page Content -->
                <div class="container-fluid">
                    @RenderBody()
                </div>
                <!-- End of Page Content -->
                </div>
            <!-- End of Main Content -->

            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <p>
                            <span>Tasarım: <a href="http://startbootstrap.com/sb-admin-v2" target="_blank">SB Admin</a></span>
                            <span>Barındırma: <a href="http://4flyy.com" target="_blank">4Flyy</a></span>
                            <span>İletişim: <a href="mailto:info@ehesabim.com">info@ehesabim.com</a></span>
