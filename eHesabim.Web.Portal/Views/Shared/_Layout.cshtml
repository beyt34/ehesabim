    <link href="//fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">

    <!-- Custom styles for this template-->
    @Styles.Render(CssBundles.SbAdmin)
    @Styles.Render(CssBundles.Kendo)
    @Styles.Render(CssBundles.Style)

    <!-- Bootstrap core JavaScript-->
    @Scripts.Render(JsBundles.JQuery)
    @Scripts.Render(JsBundles.JQueryEasing)
    @Scripts.Render(JsBundles.JQueryValidation)
    @Scripts.Render(JsBundles.Bootstrap)

