@using System.Web.Optimization
@using eHesabim.Web.Portal.Helper
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Bireysel Bütçe Takibi eHesabim.com</title>
    <meta name="description" content="Cari, K.Kartı, Kredi ve Harcama Modülleri içeren Online Bireysel Bütçe Takibi için eHesabim.com" />
    <meta name="keywords" content="bütçe, bütçe takibi, varlık yönetimi, borç alacak takibi, cari ekstre, kredi kartı, kredi, harcama takibi, alışveriş, gider takibi" />

    <link rel="icon" href="~/favicon2.ico" type="image/x-icon">
    <link rel="shortcut icon" href="~/favicon2.ico" type="image/x-icon">

    @Styles.Render(CssBundles.JQueryUi)
    @Styles.Render(CssBundles.Bootstrap)
    @Styles.Render(CssBundles.SbAdmin)
    @Styles.Render(CssBundles.Kendo)
    @Styles.Render(CssBundles.Style)

    @Scripts.Render(JsBundles.JQuery)

    @RenderSection("head", false)

    <!-- Google Analytics -->
