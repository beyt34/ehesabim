</head>
<body>
    <noscript><div><img src="https://mc.yandex.ru/watch/32268614" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <div id="wrapper">
        @Html.Partial("Menu")

        <div id="page-wrapper">

            @RenderBody()

            @Scripts.Render(JsBundles.JQueryUi)
            @Scripts.Render(JsBundles.JQueryMenu)
            @Scripts.Render(JsBundles.Bootstrap)
            @Scripts.Render(JsBundles.SbAdmin)
            @Scripts.Render(JsBundles.Kendo)
            @Scripts.Render(JsBundles.Scripts)

            <script type="text/javascript" language="javascript">
                $(document).ajaxStop($.unblockUI);
                $(document).ready(function () {
                    $('.UIButton').click(function () {
                        var form = $(this).parents('form:first');
                        if (form.valid()) {
                            BlockUI();
                        }
                    });
                });

                // kendo
                kendo.culture("tr-TR");
                var culture = kendo.culture();
                console.log(culture.name);
            </script>

            <div class="row">
                <div class="col-lg-12">
                    <p class="pull-left" style="padding-right: 20px;">Tasarım: <a href="http://startbootstrap.com/sb-admin-v2" target="_blank">SB Admin</a></p>
                    <p class="pull-left" style="padding-right: 20px;">Barındırma: <a href="http://4flyy.com" target="_blank">4Flyy</a></p>
                    <p class="pull-left">İletişim: <a href="mailto:info@ehesabim.com">info@ehesabim.com</a></p>
                    <p class="pull-right">Copyright &copy; eHesabim.com</p>
