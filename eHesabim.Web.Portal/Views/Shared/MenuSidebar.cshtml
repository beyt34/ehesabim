@using eHesabim.Framework.Localization
@using eHesabim.Services
@using eHesabim.Web.Portal.Engine
@using Kendo.Mvc.UI

<!-- Sidebar -->
<ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">
    <!-- Sidebar - Brand -->
    <a class="sidebar-brand d-flex align-items-center justify-content-center" href="@Url.RouteUrl(RouteNames.Home)">
        <div class="sidebar-brand-icon rotate-n-15">
            <i class="fas fa-laugh-wink"></i>
        </div>
        <div class="sidebar-brand-text mx-3">eHesabim</div>
    </a>
    <!-- Divider -->
    <hr class="sidebar-divider my-0">
    <!-- Nav Item - Dashboard -->
    <li class="nav-item">
        <a class="nav-link" href="@Url.RouteUrl(RouteNames.Home)">
            <i class="fas fa-fw fa-tachometer-alt"></i>
            <span>@Menus.Homepage</span>
        </a>
    </li>

    <!-- Nav Item - Pages Customer Menu -->
    <li class="nav-item">
        <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseCustomer" aria-expanded="true" aria-controls="collapseCustomer">
            <i class="fa fa-th-large fa-fw"></i>
            <span>@Menus.Customer</span>
        </a>
        <div id="collapseCustomer" class="collapse show" aria-labelledby="headingCustomer" aria-expanded="true" data-parent="#accordionSidebar">
            <div class="bg-white py-2 collapse-inner rounded">
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.CustomerList)"><i class="fa fa-book fa-fw"></i> @Menus.Customers</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.CustomerTransactionList)"><i class="fa fa-edit fa-fw"></i> @Menus.CustomerTransactions</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.CustomerAbstract)"><i class="fa fa-chart-bar fa-fw"></i> @Menus.CustomerAbstract</a>
            </div>
        </div>
    </li>

    <!-- Nav Item - Pages BankAccount Menu -->
    <li class="nav-item active">
        <a class="nav-link" href="#" data-toggle="collapse" data-target="#collapseBankAccount" aria-controls="collapseBankAccount">
            <i class="fa fa-bookmark fa-fw"></i>
            <span>@Menus.BankAccounts</span>
        </a>
        <div id="collapseBankAccount" class="collapse" aria-labelledby="headingBankAccount" data-parent="#accordionSidebar">
            <div class="bg-white py-2 collapse-inner rounded">
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankAccountList)"><i class="fa fa-fire fa-fw"></i> @Menus.BankAccounts</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankAccountTransactionList)"><i class="fa fa-pager fa-fw"></i> @Menus.BankAccountTransactions</a>
            </div>
        </div>
    </li>

    <!-- Nav Item - Pages BankCredit Menu -->
    <li class="nav-item active">
        <a class="nav-link" href="#" data-toggle="collapse" data-target="#collapseBankCredit" aria-controls="collapseBankCredit">
            <i class="fa fa-suitcase fa-fw"></i>
            <span>@Menus.BankCredits</span>
        </a>
        <div id="collapseBankCredit" class="collapse" aria-labelledby="headingBankCredit" data-parent="#accordionSidebar">
            <div class="bg-white py-2 collapse-inner rounded">
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankCreditList)"><i class="fa fa-money-bill fa-fw"></i> @Menus.BankCredits</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankCreditSubList)"><i class="fa fa-life-ring fa-fw"></i> @Menus.BankCreditSubs</a>
            </div>
        </div>
    </li>

    <!-- Nav Item - Pages BankCreditCard Menu -->
    <li class="nav-item active">
        <a class="nav-link" href="#" data-toggle="collapse" data-target="#collapseBankCreditCard" aria-controls="collapseBankCreditCard">
            <i class="fa fa-briefcase fa-fw"></i>
            <span>@Menus.BankCreditCards</span>
        </a>
        <div id="collapseBankCreditCard" class="collapse" aria-labelledby="headingBankCreditCard" data-parent="#accordionSidebar">
            <div class="bg-white py-2 collapse-inner rounded">
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankCreditCardList)"><i class="fa fa-credit-card fa-fw"></i> @Menus.BankCreditCards</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankCreditCardPeriodList)"><i class="fa fa-leaf fa-fw"></i> @Menus.BankCreditCardPeriods</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.BankCreditCardPaymentList)"><i class="fa fa-check fa-fw"></i> @Menus.BankCreditCardPayments</a>
            </div>
        </div>
    </li>

    <!-- Nav Item - Pages Expense Menu -->
    <li class="nav-item active">
        <a class="nav-link" href="#" data-toggle="collapse" data-target="#collapseExpense" aria-controls="collapseExpense">
            <i class="fa fa-spinner fa-fw"></i>
            <span>@Menus.Expense</span>
        </a>
        <div id="collapseExpense" class="collapse" aria-labelledby="headingExpense" data-parent="#accordionSidebar">
            <div class="bg-white py-2 collapse-inner rounded">
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.ExpenseList)"><i class="fa fa-barcode fa-fw"></i> @Menus.Expenses</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.ExpenseGroupReport)"><i class="fa fa-tty fa-fw"></i> @Menus.ExpenseGroupReport</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.ExpenseGroupList)"><i class="fa fa-magnet fa-fw"></i> @Menus.ExpenseGroups</a>
                <a class="collapse-item" href="@Url.RouteUrl(RouteNames.ExpenseStoreList)"><i class="fa fa-shopping-cart fa-fw"></i> @Menus.ExpenseStores</a>
            </div>
        </div>
    </li>

    <!-- Nav Item - Pages System Menu -->
    @if (WorkContext.CurrentUser.Role == PermissionTypeEnum.Admin.GetHashCode()) {
        <li class="nav-item active">
            <a class="nav-link" href="#" data-toggle="collapse" data-target="#collapseSystem" aria-controls="collapseSystem">
                <i class="fa fa-wrench fa-fw"></i>
                <span>@Menus.System</span>
            </a>
            <div id="collapseSystem" class="collapse" aria-labelledby="headingSystem" data-parent="#accordionSidebar">
                <div class="bg-white py-2 collapse-inner rounded">
                    <a class="collapse-item" href="@Url.RouteUrl(RouteNames.UserList)"><i class="fa fa-users fa-fw"></i> @Menus.Users</a>
                </div>
            </div>
        </li>
    }

    <!-- Divider -->
    <hr class="sidebar-divider d-none d-md-block">

    <!-- Sidebar Toggler (Sidebar) -->
    <div class="text-center d-none d-md-inline">
        <button class="rounded-circle border-0" id="sidebarToggle"></button>
    </div>
</ul>
<!-- End of Sidebar -->